      "settings": {
        "use_container": false,
        "custom_liquid": "{% comment %}\n    Voting Gallery - Complete Implementation (Fixed)\n  {% endcomment %}\n\n  <style>\n    .voting-gallery-snippet {\n      padding: 40px 0;\n      background-color: #ffffff;\n    }\n\n    .voting-gallery-container {\n      max-width: 1200px;\n      margin: 0 auto;\n      padding: 0 20px;\n    }\n\n    .gallery-header {\n      text-align: center;\n      margin-bottom: 40px;\n    }\n\n    .gallery-header h1 {\n      font-size: 32px;\n      margin-bottom: 10px;\n      color: #2c3e50;\n      font-weight: 600;\n    }\n\n    .gallery-header p {\n      font-size: 16px;\n      color: #6c757d;\n      margin: 0;\n    }\n\n    .gallery-filters {\n      text-align: center;\n      margin-bottom: 30px;\n    }\n\n    .filter-buttons {\n      display: inline-flex;\n      gap: 10px;\n      flex-wrap: wrap;\n      justify-content: center;\n    }\n\n    .filter-btn {\n      padding: 12px 24px;\n      border: 2px solid #dee2e6;\n      border-radius: 25px;\n      background: #ffffff;\n      color: #6c757d;\n      font-weight: 600;\n      cursor: pointer;\n      transition: all 0.2s ease;\n      text-decoration: none;\n      display: inline-block;\n    }\n\n    .filter-btn:hover,\n    .filter-btn.active {\n      border-color: #007bff;\n      background: #007bff;\n      color: #ffffff;\n      text-decoration: none;\n    }\n\n    .gallery-loading {\n      text-align: center;\n      padding: 40px;\n      color: #6c757d;\n    }\n\n    .gallery-pagination {\n      text-align: center;\n      margin-top: 40px;\n    }\n\n    .load-more-btn {\n      padding: 15px 30px;\n      background: #007bff;\n      color: #ffffff;\n      border: none;\n      border-radius: 25px;\n      font-weight: 600;\n      cursor: pointer;\n      transition: background 0.2s ease;\n    }\n\n    .load-more-btn:hover {\n      background: #0056b3;\n    }\n\n    .empty-gallery {\n      text-align: center;\n      padding: 60px 20px;\n      color: #6c757d;\n    }\n\n    .empty-gallery h3 {\n      font-size: 24px;\n      margin-bottom: 15px;\n      color: #2c3e50;\n    }\n\n    .empty-gallery p {\n      font-size: 16px;\n      margin-bottom: 20px;\n    }\n\n    .empty-gallery .cta-button {\n      display: inline-block;\n      padding: 12px 24px;\n      background: #007bff;\n      color: #ffffff;\n      text-decoration: none;\n      border-radius: 25px;\n      font-weight: 600;\n      transition: all 0.2s ease;\n    }\n\n    .empty-gallery .cta-button:hover {\n      transform: translateY(-2px);\n      box-shadow: 0 4px 8px rgba(0,0,0,0.1);\n      text-decoration: none;\n    }\n\n    /* Voting Component Styles */\n    .voting-component {\n      margin: 15px 0;\n      padding: 15px;\n      background: #f8f9fa;\n      border-radius: 12px;\n      border: 1px solid #e9ecef;\n    }\n\n    .voting-buttons {\n      display: flex;\n      gap: 15px;\n      margin-bottom: 12px;\n      justify-content: center;\n    }\n\n    .vote-btn {\n      display: flex;\n      align-items: center;\n      gap: 8px;\n      padding: 10px 16px;\n      border: 2px solid #dee2e6;\n      border-radius: 25px;\n      background: white;\n      cursor: pointer;\n      transition: all 0.2s ease;\n      font-weight: 600;\n      min-width: 80px;\n      justify-content: center;\n    }\n\n    .vote-btn:hover:not(:disabled) {\n      transform: translateY(-2px);\n      box-shadow: 0 4px 8px rgba(0,0,0,0.1);\n    }\n\n    .like-btn {\n      border-color: #28a745;\n      color: #28a745;\n    }\n\n    .like-btn:hover:not(:disabled) {\n      background: #28a745;\n      color: white;\n    }\n\n    .like-btn.voted {\n      background: #28a745;\n      color: white;\n      border-color: #28a745;\n    }\n\n    .dislike-btn {\n      border-color: #dc3545;\n      color: #dc3545;\n    }\n\n    .dislike-btn:hover:not(:disabled) {\n      background: #dc3545;\n      color: white;\n    }\n\n    .dislike-btn.voted {\n      background: #dc3545;\n      color: white;\n      border-color: #dc3545;\n    }\n\n    .voting-stats {\n      text-align: center;\n    }\n\n    .vote-percentage-bar {\n      width: 100%;\n      height: 8px;\n      background: #dc3545;\n      border-radius: 4px;\n      overflow: hidden;\n      margin-bottom: 8px;\n    }\n\n    .like-percentage {\n      height: 100%;\n      background: #28a745;\n      transition: width 0.3s ease;\n    }\n\n    .vote-stats-text {\n      display: flex;\n      justify-content: space-between;\n      align-items: center;\n      font-size: 12px;\n      color: #6c757d;\n    }\n\n    .votable-images-grid {\n      display: grid;\n      grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));\n      gap: 20px;\n      padding: 20px 0;\n    }\n\n    .votable-image-card {\n      background: white;\n      border-radius: 15px;\n      overflow: hidden;\n      box-shadow: 0 4px 6px rgba(0,0,0,0.1);\n      transition: transform 0.2s ease, box-shadow 0.2s ease;\n    }\n\n    .votable-image-card:hover {\n      transform: translateY(-4px);\n      box-shadow: 0 8px 25px rgba(0,0,0,0.15);\n    }\n\n    .image-container {\n      position: relative;\n      aspect-ratio: 3/4;\n      overflow: hidden;\n    }\n\n    .image-container img {\n      width: 100%;\n      height: 100%;\n      object-fit: cover;\n    }\n\n    .image-overlay {\n      position: absolute;\n      top: 0;\n      left: 0;\n      right: 0;\n      background: linear-gradient(to bottom, rgba(0,0,0,0.7) 0%, transparent 100%);\n      padding: 15px;\n    }\n\n    .customer-info {\n      display: flex;\n      justify-content: space-between;\n      align-items: center;\n      color: white;\n    }\n\n    .image-details {\n      padding: 15px;\n    }\n\n    .product-title {\n      font-size: 16px;\n      font-weight: 600;\n      margin: 0 0 8px 0;\n      color: #2c3e50;\n    }\n\n    @media (max-width: 768px) {\n      .voting-gallery-container {\n        padding: 0 15px;\n      }\n\n      .gallery-header h1 {\n        font-size: 24px;\n      }\n\n      .filter-btn {\n        padding: 10px 20px;\n        font-size: 14px;\n      }\n\n      .voting-gallery-snippet {\n        padding: 20px 0;\n      }\n\n      .votable-images-grid {\n        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));\n        gap: 15px;\n        padding: 15px 0;\n      }\n    }\n  </style>\n\n  <script src=\"https://changecloths--appteststore02.gadget.app/api/client/web.min.js\" defer></script>\n  <script>\n    window.shopId = \"{{ shop.id }}\";\n    window.customerId = \"{{ customer.id }}\";\n    window.customerEmail = \"{{ customer.email }}\";\n    window.customerLoginUrl = \"{{ routes.account_login_url }}\";\n\n    document.addEventListener('DOMContentLoaded', function() {\n      const checkGadget = setInterval(() => {\n        if (typeof Gadget !== 'undefined') {\n          clearInterval(checkGadget);\n          window.api = new Gadget();\n          console.log('Gadget client initialized for voting gallery');\n\n          // Initialize gallery after API is ready\n          setTimeout(initializeGallery, 500);\n        }\n      }, 100);\n    });\n\n    function initializeGallery() {\n      let currentOffset = 0;\n      let currentSort = 'newest';\n      let isLoading = false;\n\n      // Helper function to ensure API client is initialized\n      function getApiClient() {\n        if (!window.api && window.Gadget) {\n          window.api = new Gadget();\n        }\n        return window.api;\n      }\n\n      // Create voting UI components\n      function createVotingComponent(imageId, currentCounts = {}, userVote = null) {\n        const votes = {\n          likes: currentCounts.likes || 0,\n          dislikes: currentCounts.dislikes || 0,\n          total: currentCounts.total || 0,\n          likePercentage: currentCounts.likePercentage || 0\n        };\n\n        return `\n          <div class=\"voting-component\" data-image-id=\"${imageId}\">\n            <div class=\"voting-buttons\">\n              <button class=\"vote-btn like-btn ${userVote === 'like' ? 'voted' : ''}\"\n                      data-vote-type=\"like\"\n                      data-image-id=\"${imageId}\"\n                      title=\"${userVote === 'like' ? 'You liked this' : 'Like this look'}\">\n                <span class=\"vote-icon\">👍</span>\n                <span class=\"vote-count\">${votes.likes}</span>\n              </button>\n              <button class=\"vote-btn dislike-btn ${userVote === 'dislike' ? 'voted' : ''}\"\n                      data-vote-type=\"dislike\"\n                      data-image-id=\"${imageId}\"\n                      title=\"${userVote === 'dislike' ? 'You disliked this' : 'Dislike this look'}\">\n                <span class=\"vote-icon\">👎</span>\n                <span class=\"vote-count\">${votes.dislikes}</span>\n              </button>\n            </div>\n            <div class=\"voting-stats\">\n              <div class=\"vote-percentage-bar\">\n                <div class=\"like-percentage\" style=\"width: ${votes.likePercentage}%\"></div>\n              </div>\n              <div class=\"vote-stats-text\">\n                <span class=\"like-percent\">${votes.likePercentage}%</span>\n                <span class=\"total-votes\">${votes.total} votes</span>\n                <span class=\"dislike-percent\">${100 - votes.likePercentage}%</span>\n              </div>\n            </div>\n          </div>\n        `;\n      }\n\n      // Fetch and display votable images\n      async function loadVotableImages(options = {}) {\n        const apiClient = getApiClient();\n        if (!apiClient) {\n          throw new Error('Gadget API client not initialized');\n        }\n\n        const params = {\n          shopId: window.shopId?.toString(),\n          customerId: window.customerId?.toString() || null,\n          sortBy: options.sortBy || 'newest',\n          limit: options.limit || 20,\n          offset: options.offset || 0,\n          ...options\n        };\n\n        console.log('Loading votable images with params:', params);\n\n        try {\n          const response = await apiClient.getVotableImages(params);\n          const data = response.data?.getVotableImages || response.getVotableImages || response;\n\n          return data;\n        } catch (error) {\n          console.error('Failed to load votable images:', error);\n          throw error;\n        }\n      }\n\n      // Render gallery of votable images\n      function renderVotableImagesGallery(images, containerId = 'votable-images-container-main') {\n        const container = document.getElementById(containerId);\n        if (!container) {\n          console.error(`Container with ID '${containerId}' not found`);\n          return;\n        }\n\n        const galleryHTML = images.map(image => `\n          <div class=\"votable-image-card\" data-image-id=\"${image.id}\">\n            <div class=\"image-container\">\n              <img src=\"${image.imageUrl}\" alt=\"${image.productTitle}\" loading=\"lazy\" />\n              <div class=\"image-overlay\">\n                <div class=\"customer-info\">\n                  <span class=\"customer-name\">${image.customerName}</span>\n                  ${image.createdAt ? `<span class=\"created-date\">${new Date(image.createdAt).toLocaleDateString()}</span>` : ''}\n                </div>\n              </div>\n            </div>\n            <div class=\"image-details\">\n              <h3 class=\"product-title\">${image.productTitle}</h3>\n              ${image.caption ? `<p class=\"caption\">${image.caption}</p>` : ''}\n              ${image.blogArticleUrl ? `<a href=\"${image.blogArticleUrl}\" class=\"view-full-post\" target=\"_blank\">View Full Post</a>` : ''}\n            </div>\n            ${createVotingComponent(image.id, image.votes, image.userVote)}\n          </div>\n        `).join('');\n\n        container.innerHTML = `\n          <div class=\"votable-images-grid\">\n            ${galleryHTML}\n          </div>\n        `;\n      }\n\n      // Load gallery function\n      async function loadGallery(append = false) {\n        if (isLoading) return;\n        isLoading = true;\n\n        const loadingDiv = document.getElementById('gallery-loading-main');\n        const loadMoreBtn = document.getElementById('load-more-btn-main');\n        const container = document.getElementById('votable-images-container-main');\n\n        if (!append) {\n          loadingDiv.style.display = 'block';\n        }\n        loadMoreBtn.style.display = 'none';\n\n        try {\n          const urlParams = new URLSearchParams(window.location.search);\n          const customerParam = urlParams.get('customer');\n\n          const data = await loadVotableImages({\n            sortBy: currentSort,\n            limit: 24,\n            offset: currentOffset,\n            customerId: customerParam === 'community' ? null : (customerParam || window.customerId)\n          });\n\n          if (data && data.images && data.images.length > 0) {\n            if (append) {\n              const tempDiv = document.createElement('div');\n              tempDiv.id = 'temp-container-main';\n              document.body.appendChild(tempDiv);\n              renderVotableImagesGallery(data.images, tempDiv.id);\n\n              const existingGrid = container.querySelector('.votable-images-grid');\n              const newGrid = tempDiv.querySelector('.votable-images-grid');\n\n              if (existingGrid && newGrid) {\n                const newImages = newGrid.querySelectorAll('.votable-image-card');\n                newImages.forEach(img => existingGrid.appendChild(img));\n              } else if (newGrid) {\n                container.appendChild(newGrid);\n              }\n\n              tempDiv.remove();\n            } else {\n              renderVotableImagesGallery(data.images, 'votable-images-container-main');\n            }\n\n            if (data.pagination && data.pagination.hasMore) {\n              loadMoreBtn.style.display = 'block';\n            }\n          } else if (!append) {\n            container.innerHTML = `\n              <div class=\"empty-gallery\">\n                <h3>No looks found yet!</h3>\n                <p>Be the first to share your virtual try-on look with the community.</p>\n                <a href=\"/collections/all\" class=\"cta-button\">Try Virtual Try-On</a>\n              </div>\n            `;\n          }\n        } catch (error) {\n          console.error('Failed to load gallery:', error);\n          container.innerHTML = `\n            <div class=\"empty-gallery\">\n              <h3>Unable to Load Gallery</h3>\n              <p>There was an error loading the gallery. Please try again later.</p>\n            </div>\n          `;\n        } finally {\n          isLoading = false;\n          loadingDiv.style.display = 'none';\n        }\n      }\n\n      // Filter button handlers\n      document.querySelectorAll('#voting-gallery-main .filter-btn').forEach(btn => {\n        btn.addEventListener('click', function() {\n          document.querySelectorAll('#voting-gallery-main .filter-btn').forEach(b => b.classList.remove('active'));\n          this.classList.add('active');\n\n          currentSort = this.dataset.sort;\n          currentOffset = 0;\n          document.getElementById('votable-images-container-main').innerHTML = '';\n          loadGallery();\n        });\n      });\n\n      // Load more button handler\n      document.getElementById('load-more-btn-main').addEventListener('click', function() {\n        currentOffset += 24;\n        loadGallery(true);\n      });\n\n      // Load initial gallery\n      loadGallery();\n    }\n  </script>\n\n  <div class=\"voting-gallery-snippet\" id=\"voting-gallery-main\">\n    <div class=\"voting-gallery-container\">\n      <div class=\"gallery-header\">\n        <h1>Community Looks</h1>\n        <p>Vote on amazing virtual try-on styles!</p>\n      </div>\n\n      <div class=\"gallery-filters\">\n        <div class=\"filter-buttons\">\n          <button class=\"filter-btn active\" data-sort=\"newest\">Newest</button>\n          <button class=\"filter-btn\" data-sort=\"mostVoted\">Most Voted</button>\n          <button class=\"filter-btn\" data-sort=\"mostLiked\">Most Liked</button>\n        </div>\n      </div>\n\n      <div class=\"gallery-loading\" id=\"gallery-loading-main\" style=\"display: block;\">\n        <p>Loading virtual try-on gallery...</p>\n      </div>\n\n      <div id=\"votable-images-container-main\">\n        <!-- Gallery images will be loaded here dynamically -->\n      </div>\n\n      <div class=\"gallery-pagination\">\n        <button class=\"load-more-btn\" id=\"load-more-btn-main\" style=\"display: none;\">\n          Load More\n        </button>\n      </div>\n    </div>\n  </div>"
      }
    }
  },
