{%- liquid
  assign hero_image = section.settings.image
  assign mobile_image = section.settings.mobile_image | default: hero_image
  assign primary_url = section.settings.primary_link | default: routes.all_products_collection_url
  assign secondary_url = section.settings.secondary_link | default: routes.all_products_collection_url
  assign image_alt = hero_image.alt | default: section.settings.heading | strip_html | escape
-%}

<section id="MSDLuxuryHero-{{ section.id }}" class="msd-luxury-hero" style="--msd-hero-bg: {{ section.settings.background_color }}; --msd-hero-ink: {{ section.settings.text_color }}; --msd-hero-muted: {{ section.settings.muted_color }};">
  <style>
    #MSDLuxuryHero-{{ section.id }}{background:var(--msd-hero-bg);color:var(--msd-hero-ink);border-bottom:1px solid rgba(10,10,10,.10)}
    #MSDLuxuryHero-{{ section.id }} .msd-luxury-hero__grid{display:grid;grid-template-columns:minmax(0,.95fr) minmax(0,1.05fr);min-height:min(720px, calc(100vh - 124px))}
    #MSDLuxuryHero-{{ section.id }} .msd-luxury-hero__copy{display:flex;flex-direction:column;justify-content:center;padding:72px 40px 48px;max-width:680px}
    #MSDLuxuryHero-{{ section.id }} .msd-luxury-hero__eyebrow{margin:0 0 18px;font-family:'DM Sans',Helvetica,Arial,sans-serif;font-size:11px;line-height:1;text-transform:uppercase;letter-spacing:.16em;font-weight:700;color:#5a31f4}
    #MSDLuxuryHero-{{ section.id }} .msd-luxury-hero__heading{margin:0;font-family:'Bebas Neue',Helvetica,sans-serif;font-size:clamp(58px,8.5vw,132px);line-height:.86;letter-spacing:0;text-transform:uppercase;color:var(--msd-hero-ink)}
    #MSDLuxuryHero-{{ section.id }} .msd-luxury-hero__body{max-width:520px;margin:22px 0 0;font-family:'DM Sans',Helvetica,Arial,sans-serif;font-size:clamp(16px,1.4vw,20px);line-height:1.5;font-weight:300;color:var(--msd-hero-muted)}
    #MSDLuxuryHero-{{ section.id }} .msd-luxury-hero__actions{display:flex;flex-wrap:wrap;gap:10px;margin-top:30px}
    #MSDLuxuryHero-{{ section.id }} .msd-luxury-hero__btn{display:inline-flex;align-items:center;justify-content:center;min-height:52px;padding:0 24px;border:1px solid var(--msd-hero-ink);border-radius:0;font-family:'DM Sans',Helvetica,Arial,sans-serif;font-size:11px;font-weight:700;letter-spacing:.12em;line-height:1;text-transform:uppercase;text-decoration:none}
    #MSDLuxuryHero-{{ section.id }} .msd-luxury-hero__btn--primary{background:#5a31f4;border-color:#5a31f4;color:#fff}
    #MSDLuxuryHero-{{ section.id }} .msd-luxury-hero__btn--secondary{background:transparent;color:var(--msd-hero-ink)}
    #MSDLuxuryHero-{{ section.id }} .msd-luxury-hero__btn:hover{background:#0a0a0a;border-color:#0a0a0a;color:#fff}
    #MSDLuxuryHero-{{ section.id }} .msd-luxury-hero__stats{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:1px;max-width:560px;margin-top:auto;padding-top:48px}
    #MSDLuxuryHero-{{ section.id }} .msd-luxury-hero__stat{border:1px solid rgba(10,10,10,.12);background:rgba(255,255,255,.48);padding:15px 14px}
    #MSDLuxuryHero-{{ section.id }} .msd-luxury-hero__stat-value{display:block;font-family:'Bebas Neue',Helvetica,sans-serif;font-size:30px;line-height:.95;text-transform:uppercase;color:var(--msd-hero-ink)}
    #MSDLuxuryHero-{{ section.id }} .msd-luxury-hero__stat-label{display:block;margin-top:4px;font-family:'DM Sans',Helvetica,Arial,sans-serif;font-size:10px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--msd-hero-muted)}
    #MSDLuxuryHero-{{ section.id }} .msd-luxury-hero__media{position:relative;min-height:620px;overflow:hidden;background:#e9e5dd}
    #MSDLuxuryHero-{{ section.id }} .msd-luxury-hero__media a,
    #MSDLuxuryHero-{{ section.id }} .msd-luxury-hero__media picture{display:block;height:100%;min-height:inherit}
    #MSDLuxuryHero-{{ section.id }} .msd-luxury-hero__image{width:100%;height:100%;min-height:inherit;object-fit:cover;object-position:center}
    #MSDLuxuryHero-{{ section.id }} .msd-luxury-hero__placeholder{display:flex;align-items:center;justify-content:center;width:100%;height:100%;min-height:inherit;background:#e9e5dd}
    #MSDLuxuryHero-{{ section.id }} .msd-luxury-hero__placeholder svg{width:100%;height:100%;max-width:520px;color:rgba(10,10,10,.18)}
    @media (max-width:989px){
      #MSDLuxuryHero-{{ section.id }} .msd-luxury-hero__grid{grid-template-columns:1fr;min-height:0}
      #MSDLuxuryHero-{{ section.id }} .msd-luxury-hero__copy{order:2;padding:34px 20px 28px;max-width:none}
      #MSDLuxuryHero-{{ section.id }} .msd-luxury-hero__media{order:1;min-height:42vh}
      #MSDLuxuryHero-{{ section.id }} .msd-luxury-hero__stats{grid-template-columns:1fr 1fr 1fr;padding-top:28px}
      #MSDLuxuryHero-{{ section.id }} .msd-luxury-hero__stat{padding:12px 10px}
      #MSDLuxuryHero-{{ section.id }} .msd-luxury-hero__stat-value{font-size:23px}
    }
    @media (max-width:540px){
      #MSDLuxuryHero-{{ section.id }} .msd-luxury-hero__heading{font-size:56px}
      #MSDLuxuryHero-{{ section.id }} .msd-luxury-hero__actions{display:grid;grid-template-columns:1fr}
    }
  </style>

  <div class="msd-luxury-hero__grid">
    <div class="msd-luxury-hero__copy">
      {%- if section.settings.eyebrow != blank -%}
        <p class="msd-luxury-hero__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h1 class="msd-luxury-hero__heading">{{ section.settings.heading | escape | newline_to_br }}</h1>
      {%- endif -%}
      {%- if section.settings.body != blank -%}
        <p class="msd-luxury-hero__body">{{ section.settings.body | escape }}</p>
      {%- endif -%}
      <div class="msd-luxury-hero__actions">
        {%- if section.settings.primary_label != blank -%}
          <a class="msd-luxury-hero__btn msd-luxury-hero__btn--primary" href="{{ primary_url }}">{{ section.settings.primary_label | escape }}</a>
        {%- endif -%}
        {%- if section.settings.secondary_label != blank -%}
          <a class="msd-luxury-hero__btn msd-luxury-hero__btn--secondary" href="{{ secondary_url }}">{{ section.settings.secondary_label | escape }}</a>
        {%- endif -%}
      </div>
      <div class="msd-luxury-hero__stats" aria-label="Store highlights">
        <span class="msd-luxury-hero__stat">
          <span class="msd-luxury-hero__stat-value">{{ section.settings.stat_1_value | escape }}</span>
          <span class="msd-luxury-hero__stat-label">{{ section.settings.stat_1_label | escape }}</span>
        </span>
        <span class="msd-luxury-hero__stat">
          <span class="msd-luxury-hero__stat-value">{{ section.settings.stat_2_value | escape }}</span>
          <span class="msd-luxury-hero__stat-label">{{ section.settings.stat_2_label | escape }}</span>
        </span>
        <span class="msd-luxury-hero__stat">
          <span class="msd-luxury-hero__stat-value">{{ section.settings.stat_3_value | escape }}</span>
          <span class="msd-luxury-hero__stat-label">{{ section.settings.stat_3_label | escape }}</span>
        </span>
      </div>
    </div>
    <div class="msd-luxury-hero__media">
      <a href="{{ primary_url }}" aria-label="{{ section.settings.primary_label | default: 'Shop now' | escape }}">
        {%- if hero_image != blank -%}
          <picture>
            {%- if mobile_image != blank -%}
              <source media="(max-width: 767px)" srcset="{{ mobile_image | image_url: width: 900 }}">
            {%- endif -%}
            {{ hero_image | image_url: width: 1800 | image_tag: widths: '720, 960, 1200, 1600, 1800', sizes: '(min-width: 990px) 50vw, 100vw', class: 'msd-luxury-hero__image', loading: 'eager', alt: image_alt }}
          </picture>
        {%- else -%}
          <div class="msd-luxury-hero__placeholder">
            {{ 'lifestyle-1' | placeholder_svg_tag }}
          </div>
        {%- endif -%}
      </a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "MSD: Luxury hero",
  "tag": "section",
  "class": "section-msd-luxury-hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Desktop image"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile image"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "New Season Edit"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "Dressed to own it."
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body",
      "default": "Curated pieces for women who move with intention. New arrivals, every Friday."
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary button label",
      "default": "Shop now"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary button label",
      "default": "Explore lookbook"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Secondary button link"
    },
    {
      "type": "text",
      "id": "stat_1_value",
      "label": "Stat 1 value",
      "default": "3.2 million+"
    },
    {
      "type": "text",
      "id": "stat_1_label",
      "label": "Stat 1 label",
      "default": "Happy customers"
    },
    {
      "type": "text",
      "id": "stat_2_value",
      "label": "Stat 2 value",
      "default": "Loved by"
    },
    {
      "type": "text",
      "id": "stat_2_label",
      "label": "Stat 2 label",
      "default": "MsDressly customers"
    },
    {
      "type": "text",
      "id": "stat_3_value",
      "label": "Stat 3 value",
      "default": "45-day"
    },
    {
      "type": "text",
      "id": "stat_3_label",
      "label": "Stat 3 label",
      "default": "Returns"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#f7f5f2"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#0a0a0a"
    },
    {
      "type": "color",
      "id": "muted_color",
      "label": "Muted text",
      "default": "#6f6a64"
    }
  ],
  "presets": [
    {
      "name": "MSD: Luxury hero"
    }
  ]
}
{% endschema %}
