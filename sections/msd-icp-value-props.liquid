<section id="MSDValueProps-{{ section.id }}" class="msd-value-props msd-value-props--{{ section.settings.tone }}" style="--msd-vp-bg: {{ section.settings.bg_color }}; --msd-vp-ink: {{ section.settings.text_color }}; --msd-vp-muted: {{ section.settings.muted_color }}; --msd-vp-accent: {{ section.settings.accent_color }};">
  <style>
    .msd-value-props{background:var(--msd-vp-bg);color:var(--msd-vp-ink)}
    .msd-value-props__inner{padding:38px 0}
    .msd-value-props__layout{display:grid;grid-template-columns:minmax(0,.72fr) minmax(0,1.45fr);gap:28px;align-items:start}
    .msd-value-props__eyebrow{margin:0 0 10px;font-size:11px;line-height:1.3;text-transform:uppercase;letter-spacing:.14em;font-weight:700;color:var(--msd-vp-accent)}
    .msd-value-props__heading{margin:0;font-family:'Bebas Neue',Helvetica,sans-serif;font-size:clamp(34px,4vw,56px);line-height:.94;letter-spacing:0;text-transform:uppercase;color:var(--msd-vp-ink)}
    .msd-value-props__body{margin-top:14px;color:var(--msd-vp-muted);font-size:16px;line-height:1.6}
    .msd-value-props__grid{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:1px}
    .msd-value-props__item{border:1px solid rgba(10,10,10,.12);border-radius:0;background:rgba(255,255,255,.92);padding:18px;min-height:150px}
    .msd-value-props__label{margin:0 0 8px;font-size:10px;line-height:1.3;text-transform:uppercase;letter-spacing:.14em;font-weight:700;color:var(--msd-vp-accent)}
    .msd-value-props__title{margin:0 0 8px;font-family:'Bebas Neue',Helvetica,sans-serif;font-size:24px;line-height:1;text-transform:uppercase;color:var(--msd-vp-ink)}
    .msd-value-props__text{margin:0;color:var(--msd-vp-muted);font-size:14px;line-height:1.55}
    .msd-value-props__actions{display:flex;align-items:center;gap:12px;flex-wrap:wrap;margin-top:22px}
    .msd-value-props__link{font-weight:700;color:var(--msd-vp-ink);text-decoration:underline;text-underline-offset:3px}
    .msd-value-props--compact .msd-value-props__inner{padding:30px 0}
    .msd-value-props--compact .msd-value-props__layout{grid-template-columns:minmax(0,.75fr) minmax(0,1.4fr)}
    .msd-value-props--compact .msd-value-props__item{min-height:136px}
    @media (max-width:990px){
      .msd-value-props__layout,.msd-value-props--compact .msd-value-props__layout{grid-template-columns:1fr}
      .msd-value-props__grid{grid-template-columns:repeat(2,minmax(0,1fr))}
    }
    @media (max-width:540px){
      .msd-value-props__grid{grid-template-columns:1fr}
    }
  </style>

  <div{% if section.settings.container == 'boxed' %} class="container"{% endif %}>
    <div class="msd-value-props__inner">
      <div class="msd-value-props__layout">
        <div class="msd-value-props__copy">
          {%- if section.settings.eyebrow != blank -%}
            <p class="msd-value-props__eyebrow">{{ section.settings.eyebrow | escape }}</p>
          {%- endif -%}
          {%- if section.settings.heading != blank -%}
            <h2 class="msd-value-props__heading">{{ section.settings.heading | escape }}</h2>
          {%- endif -%}
          {%- if section.settings.body != blank -%}
            <div class="msd-value-props__body rte">{{ section.settings.body }}</div>
          {%- endif -%}
          {%- if section.settings.primary_label != blank or section.settings.secondary_label != blank -%}
            <div class="msd-value-props__actions">
              {%- if section.settings.primary_label != blank and section.settings.primary_link != blank -%}
                <a href="{{ section.settings.primary_link }}" class="btn btn--default btn--size-middle">{{ section.settings.primary_label | escape }}</a>
              {%- endif -%}
              {%- if section.settings.secondary_label != blank and section.settings.secondary_link != blank -%}
                <a href="{{ section.settings.secondary_link }}" class="msd-value-props__link">{{ section.settings.secondary_label | escape }}</a>
              {%- endif -%}
            </div>
          {%- endif -%}
        </div>

        {%- if section.blocks.size > 0 -%}
          <div class="msd-value-props__grid">
            {%- for block in section.blocks -%}
              <article class="msd-value-props__item" {{ block.shopify_attributes }}>
                {%- if block.settings.label != blank -%}
                  <p class="msd-value-props__label">{{ block.settings.label | escape }}</p>
                {%- endif -%}
                {%- if block.settings.title != blank -%}
                  <h3 class="msd-value-props__title">{{ block.settings.title | escape }}</h3>
                {%- endif -%}
                {%- if block.settings.text != blank -%}
                  <p class="msd-value-props__text">{{ block.settings.text | escape }}</p>
                {%- endif -%}
              </article>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "MSD: Value props",
  "tag": "section",
  "class": "section-msd-value-props",
  "settings": [
    {
      "type": "select",
      "id": "container",
      "label": "Content width",
      "default": "boxed",
      "options": [
        { "value": "boxed", "label": "Boxed" },
        { "value": "fullwidth", "label": "Fullwidth" }
      ]
    },
    {
      "type": "select",
      "id": "tone",
      "label": "Tone",
      "default": "standard",
      "options": [
        { "value": "standard", "label": "Standard" },
        { "value": "compact", "label": "Compact" }
      ]
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "First-order confidence"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Premium style, clear value."
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body",
      "default": "<p>Enjoy $80 free shipping progress, 45-day returns, secure checkout, and the $49/month refresh box designed to keep your wardrobe ready.</p>"
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary button label",
      "default": "Shop customer favorites"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary link label",
      "default": "Explore new arrivals"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Secondary link"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#0a0a0a"
    },
    {
      "type": "color",
      "id": "muted_color",
      "label": "Muted text",
      "default": "#6f6a64"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent",
      "default": "#5a31f4"
    }
  ],
  "blocks": [
    {
      "type": "point",
      "name": "Point",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "Fit" },
        { "type": "text", "id": "title", "label": "Title", "default": "Fit confidence first" },
        { "type": "textarea", "id": "text", "label": "Text", "default": "Clear silhouettes, practical sizing, and easy styling notes help reduce second-guessing." }
      ]
    }
  ],
  "presets": [
    {
      "name": "MSD: Value props",
      "blocks": [
        {
          "type": "point",
          "settings": {
            "label": "Shipping",
            "title": "Free over $80",
            "text": "Priority shipping is unlocked once your order crosses the $80 threshold."
          }
        },
        {
          "type": "point",
          "settings": {
            "label": "Returns",
            "title": "45-day returns",
            "text": "Eligible items are backed by a longer at-home try-on window."
          }
        },
        {
          "type": "point",
          "settings": {
            "label": "Quality",
            "title": "Polished details",
            "text": "Curated silhouettes, practical sizing notes, and secure checkout support confident orders."
          }
        },
        {
          "type": "point",
          "settings": {
            "label": "Subscribe",
            "title": "Save on essentials",
            "text": "Start the $49/month refresh box when you want monthly backup pairs handled."
          }
        }
      ]
    }
  ]
}
{% endschema %}
