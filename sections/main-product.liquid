{%- # theme-check-disable UndefinedObject, DeprecatedTag -%}
{% include 'global-variables' %}
{%- assign template_layout = settings.product_info_layout -%}
{%- if product.tags contains 'gallery-layout-1' -%}
    {%- assign template_layout = '1' -%}
{%- elsif product.tags contains 'gallery-layout-2' -%}
    {%- assign template_layout = '2' -%}
{%- elsif product.tags contains 'gallery-layout-3' -%}
    {%- assign template_layout = '3' -%}
{%- elsif product.tags contains 'gallery-layout-4' -%}
    {%- assign template_layout = '4' -%}
{%- elsif product.tags contains 'gallery-layout-5' -%}
    {%- assign template_layout = '5' -%}
{%- endif -%}
{%- assign sidebar = section.settings.sidebar -%}
{%- if template_layout == '3' or template_layout == '4' -%}
	{%- assign enable_sticky_sidebar = true -%}
{%- else -%}
	{%- assign enable_sticky_sidebar = section.settings.enable_sticky_sidebar -%}
{%- endif -%}
{% capture container_class %}{% if sidebar != 'off' %} product-page__container--with-sidebar{% endif %}{% if sidebar == 'left' %} order-xl-1{% endif %}{% endcapture %}
{% capture sidebar_class %}{% if sidebar == 'left' %} product-page__sidebar--left pr-xl-30 mr-xl-30{% elsif sidebar == 'right' %} product-page__sidebar--right pl-xl-30 ml-xl-30{% endif %}{% endcapture %}
{% capture sidebar_html %}
	{%- if sidebar != 'off' -%}
		<div class="product-page__sidebar{{ sidebar_class }}{% if enable_sticky_sidebar %} sticky-sidebar-xl js-sticky-sidebar{% endif %}" data-js-sticky-sidebar-media-xl>
			{%- if enable_sticky_sidebar -%}
				<div data-js-sticky-sidebar-body>
			{%- endif -%}
				<div data-js-position-desktop="sidebar">
					{% include 'product-page-get-sidebar' %}
				</div>
			{%- if enable_sticky_sidebar -%}
				</div>
			{%- endif -%}
			</div>
	{%- endif -%}
{% endcapture %}
{% include 'product-res-variables' %}
{% capture content_margins %}pt-{{ offset_product_page_content_margin_top_d }} pb-{{ offset_product_page_content_margin_bottom_d }}{% endcapture %}
<div class="product-page {{ content_margins }}">
	<div class="container{% if sidebar != 'off' %} d-xl-flex{% endif %}">
		{%- if template_layout == '1' or template_layout == '5' -%}
			<div class="product-page__container{{ container_class }}">
				<div class="product-page__main">
					{% include 'product-page-get-main' %}
				</div>
				{%- if section.settings.show_tabs -%}
					<div class="product-page__tabs mt-30">
						{% include 'product-page-get-tabs' %}
					</div>
				{%- endif -%}
			</div>
			{{ sidebar_html }}
		{%- else -%}
			<div class="product-page__container{{ container_class }}">
				<div class="product-page__main">
					{% include 'product-page-get-main' %}
				</div>
			</div>
			{{ sidebar_html }}
		{%- endif -%}
	</div>
</div>

{%- if enable_sticky_sidebar -%}
	<script>
		theme.AssetsLoader.require('scripts', 'sticky_sidebar');
	</script>
{%- endif -%}
<script>
    if (window.msdresslyRequireProductPageAssets) {
        window.msdresslyRequireProductPageAssets();
    } else {
        theme.AssetsLoader.onPageLoaded(function() {
            theme.AssetsLoader.require('styles', 'plugin_slick');
            theme.AssetsLoader.require('scripts', 'product_page');
        });
    }
</script>
{%- if section.settings.tabs_type == 'tabs' -%}
	<script>
		theme.AssetsLoader.onUserAction(function() {
			theme.AssetsLoader.require('scripts', 'tabs');
		});
	</script>
{%- endif -%}

{%- if section.settings.enable_floating_video -%}
	<div class="product-floating-video d-none{% if section.settings.floating_video_hide_on_mobile %} product-floating-video--hide-mobile{% endif %}" data-floating-video-container="{{ section.id }}">
		<button type="button" class="product-floating-video__close" aria-label="Close floating video" data-floating-video-close>&times;</button>
		<button type="button" class="product-floating-video__mute" aria-label="Toggle sound" aria-pressed="true" data-floating-video-mute>Unmute</button>
		<div class="product-floating-video__inner" data-floating-video-slot></div>
	</div>
	<style>
		.product-floating-video{position:fixed;top:50%;left:16px;width:320px;max-width:calc(100vw - 30px);max-height:70vh;z-index:9999;border-radius:12px;overflow:hidden;background:#000;box-shadow:0 20px 40px rgba(0,0,0,0.35);transition:opacity .2s ease,transform .2s ease;opacity:0;transform:translateY(calc(-50% + 12px));pointer-events:none}
		.product-floating-video--visible{opacity:1;transform:translateY(-50%);pointer-events:auto}
		.product-floating-video--portrait{width:240px;max-width:min(260px,40vw);max-height:80vh}
		.product-floating-video--portrait .product-floating-video__inner{aspect-ratio:9/16}
		.product-floating-video video,.product-floating-video iframe{width:100%;height:100%;display:block;border:0;background:#000}
		.product-floating-video__inner{position:relative;aspect-ratio:16/9;background:#000}
		.product-floating-video__close{position:absolute;top:6px;right:8px;width:32px;height:32px;border:0;border-radius:50%;background:rgba(0,0,0,0.6);color:#fff;cursor:pointer;font-size:20px;line-height:1;z-index:2;display:flex;align-items:center;justify-content:center;transition:background .2s ease,opacity .2s ease}
		.product-floating-video__close:hover{background:rgba(0,0,0,0.75)}
		.product-floating-video__mute{position:absolute;bottom:8px;left:8px;height:32px;min-width:70px;padding:0 12px;border:0;border-radius:16px;background:rgba(0,0,0,0.6);color:#fff;font-size:12px;line-height:1;cursor:pointer;z-index:2;display:flex;align-items:center;justify-content:center;transition:background .2s ease,opacity .2s ease}
		.product-floating-video__mute:hover{background:rgba(0,0,0,0.75)}
		.product-floating-video.d-none{display:none!important}
		@media (max-width:767px){
			.product-floating-video{width:260px;left:10px;top:50%;max-height:65vh;transform:translateY(calc(-50% + 12px))}
			.product-floating-video--visible{transform:translateY(-50%)}
			.product-floating-video--portrait{width:200px;max-width:70vw;max-height:75vh}
			.product-floating-video--hide-mobile{display:none!important}
		}
	</style>
	<script type="application/json" id="ProductFloatingVideoData-{{ section.id }}">
	  {
		"src": null,
		"audio_src": {{ product.metafields.custom.audio_sales_pitch.value.url | json }},
		"hide_on_mobile": {{ section.settings.floating_video_hide_on_mobile | default: false | json }}
	  }
	</script>
	<script type="application/json" id="ProductFloatingVideoPool-{{ section.id }}">
		{{ section.settings.video_pool_json | json }}
	</script>
	<script>
	(function() {
        // Safe debug logging - only logs when ThemeDebug exists and is enabled
        var debugLog = (window.ThemeDebug && ThemeDebug.enabled)
            ? function() { ThemeDebug.log.apply(ThemeDebug, arguments); }
            : function() {};

        debugLog("Floating Video Script Loaded");
        var PRESERVED_AUDIO_SRC = null; // Robust capture variable
		var dataEl = document.getElementById('ProductFloatingVideoData-{{ section.id }}');
		var poolEl = document.getElementById('ProductFloatingVideoPool-{{ section.id }}');

		if (!dataEl) return;
		var data;
		try { 
            data = JSON.parse(dataEl.textContent); 
            if (data && data.audio_src) {
                PRESERVED_AUDIO_SRC = data.audio_src;
            }
        } catch (e) { return; }
		
		// Fallback to pool if no specific video is defined
		if (!data || !data.src) {
			if (poolEl) {
				var poolData;
				try { poolData = JSON.parse(poolEl.textContent); } catch (e) {}
				
				// Handle if the setting is a string containing JSON (textarea)
				if (typeof poolData === 'string') {
					try { poolData = JSON.parse(poolData); } catch (e) {}
				}

				if (Array.isArray(poolData) && poolData.length > 0) {
					var validItems = poolData.filter(function(item) {
						return item && (item.id || item.video_id || item.src);
					});
					
					if (validItems.length > 0) {
						var randomItem = validItems[Math.floor(Math.random() * validItems.length)];
						var pHost = (randomItem.host || randomItem.video_host || 'youtube').toLowerCase();
						var pId = randomItem.id || randomItem.video_id || randomItem.src;
						var pPoster = randomItem.poster || randomItem.video_poster || '';
						
						// Basic MP4/Ext detection
						var pType = (pHost === 'mp4') ? 'video' : 'external_video';
						
						data = {
							type: pType,
							host: pHost,
							src: pId,
							poster: pPoster,
							aspect_ratio: randomItem.aspect_ratio || randomItem.ratio || ''
						};
					}
				}
			}
		}

		if (!data || !data.src) return;


		var container = document.querySelector('[data-floating-video-container="{{ section.id }}"]');
		var slot = container && container.querySelector('[data-floating-video-slot]');
		var closeBtn = container && container.querySelector('[data-floating-video-close]');
		var muteBtn = container && container.querySelector('[data-floating-video-mute]');
		var gallery = document.querySelector('[data-js-product-gallery]');
		if (!container || !slot || !gallery) return;

		if (window.Shopify && Shopify.designMode) return;

		var mql = window.matchMedia('(max-width: 767px)');
		var hideOnMobile = {{ section.settings.floating_video_hide_on_mobile | json }};
		var dismissed = false;
		var observer;
		var userScrolled = false;
		var currentIframe = null;
		var currentVideo = null;
		var isMuted = true;
		var posterOrientation = null;
		var audioPlayer = null;

		if (data.poster) {
			var posterImg = new Image();
			posterImg.onload = function() {
				if (this.height > this.width) {
					posterOrientation = 'portrait';
					container.classList.add('product-floating-video--portrait');
					slot.style.aspectRatio = 0.5625;
				} else {
					posterOrientation = 'landscape';
				}
			};
			posterImg.src = data.poster;
		}

		function updateMuteLabel() {
			if (!muteBtn) return;
			muteBtn.textContent = isMuted ? 'Unmute' : 'Mute';
		}

		function clearPlayer() {
			slot.innerHTML = '';
			currentIframe = null;
			currentVideo = null;
			if (audioPlayer) {
				audioPlayer.pause();
			}
		}

		function buildPlayer() {
			if (slot.childElementCount) return;
			var ratio = parseFloat(data.aspect_ratio);
			if (!ratio || isNaN(ratio)) {
				ratio = 1.777;
			}
			if (posterOrientation === 'portrait') {
				ratio = 9 / 16;
			}
			// Force portrait layout for YouTube Shorts-style vertical videos when width < height from poster or aspect hints
			if (data.type === 'external_video' && (posterOrientation === 'portrait' || ratio < 1.1)) {
				ratio = 9 / 16;
			}
			var isPortrait = ratio < 0.9 || posterOrientation === 'portrait';
			if (isPortrait) {
				container.classList.add('product-floating-video--portrait');
			} else {
				container.classList.remove('product-floating-video--portrait');
			}
			slot.style.aspectRatio = ratio;
			if (data.poster) {
				slot.style.backgroundImage = 'url(' + data.poster + ')';
				slot.style.backgroundSize = 'cover';
				slot.style.backgroundPosition = 'center';
			}

			if (data.type === 'video') {
				var video = document.createElement('video');
				video.src = data.src;
				video.poster = data.poster;
				video.muted = true;
				video.playsInline = true;
				video.loop = true;
				video.autoplay = true; 
				video.style.width = '100%';
				video.style.height = '100%';
				video.style.objectFit = 'cover';
				
				// Auto-detect aspect ratio for MP4s if no override is provided
				video.addEventListener('loadedmetadata', function() {
					if (!data.aspect_ratio && this.videoWidth && this.videoHeight) {
						var vRatio = this.videoWidth / this.videoHeight;
						slot.style.aspectRatio = vRatio;
						if (vRatio < 0.9) {
							container.classList.add('product-floating-video--portrait');
						} else {
							container.classList.remove('product-floating-video--portrait');
						}
					}
				});

				slot.appendChild(video);
				currentVideo = video;
				
				// Attempt autoplay
				var promise = video.play();
				if (promise !== undefined) {
					promise.catch(function(error) {
						// Auto-play was prevented
					});
				}
			} else {
				var iframe = document.createElement('iframe');
				var iframeSrc;
				var host = (data.host || 'youtube').toLowerCase();
				if (host === 'vimeo') {
					iframeSrc = 'https://player.vimeo.com/video/' + data.src + '?autoplay=1&loop=1&muted=1&title=0&byline=0&controls=0';
				} else { // Default to YouTube
					iframeSrc = 'https://www.youtube.com/embed/' + data.src + '?autoplay=1&loop=1&mute=1&playlist=' + data.src + '&controls=0&modestbranding=1&showinfo=0&rel=0&playsinline=1&enablejsapi=1';
				}
				iframe.src = iframeSrc;
				iframe.style.width = '100%';
				iframe.style.height = '100%';
				iframe.style.border = '0';
				iframe.allow = "autoplay; encrypted-media; picture-in-picture";
				iframe.loading = 'lazy';
				
				slot.appendChild(iframe);
				currentIframe = iframe;
			}
			
			updateMuteLabel();
		}

		function updateMuteLabel() {
			if (muteBtn) {
				var text = isMuted ? 'Unmute' : 'Mute';
				// You can change icon/text here
				muteBtn.textContent = text;
                muteBtn.setAttribute('aria-pressed', isMuted);
			}
		}

		function setMuteState(muted) {
			isMuted = muted;
			if (currentVideo) {
				currentVideo.muted = muted;
				if (!muted) {
					currentVideo.play().catch(function(){});
				}
			}

            // Audio Sales Pitch Logic
            if (currentIframe && currentIframe.contentWindow) {
				var cmd = muted ? 'mute' : 'unMute';
				try {
					currentIframe.contentWindow.postMessage(JSON.stringify({ event: 'command', func: cmd, args: [] }), '*');
					if (data.host === 'vimeo') {
						currentIframe.contentWindow.postMessage(JSON.stringify({ method: 'setVolume', value: muted ? 0 : 1 }), '*');
					}
					if (!muted && data.host === 'youtube') {
						currentIframe.contentWindow.postMessage(JSON.stringify({ event: 'command', func: 'playVideo', args: [] }), '*');
					}
				} catch (e) {}
			}

            if (!muted && !audioPlayer && PRESERVED_AUDIO_SRC) {
                try {
                    var audioUrl = PRESERVED_AUDIO_SRC;
                     // Ensure protocol if missing (common in Shopify files)
                    if (audioUrl.indexOf('//') === 0) {
                        audioUrl = 'https:' + audioUrl;
                    }
                    debugLog("Audio Sales Pitch: Initializing player with URL", audioUrl);
                    
                    audioPlayer = new Audio(audioUrl);
                    audioPlayer.loop = true;
                    
                    // Add error listener
                    audioPlayer.addEventListener('error', function(e) {
                         console.error("Audio Player Error Event:", e);
                    });
                     
                } catch (e) {
                    console.error("Audio Sales Pitch: Error initializing player", e);
                }
            } else {
                 debugLog("Audio Sales Pitch: Skipping initialization. Reason:",
                    muted ? "Muted" : (audioPlayer ? "Player Exists" : "No Audio Src"));
            }

            if (audioPlayer) {
				if (muted) {
					audioPlayer.pause();
				} else {
debugLog("Audio Sales Pitch: Attempting to play...");
				var playPromise = audioPlayer.play();
                    if (playPromise !== undefined) {
                        playPromise.then(function() {
                            debugLog("Audio playback started successfully");
                        }).catch(function(error) {
                            console.error("Audio playback failed:", error);
                        });
                    }
				}
			}
			updateMuteLabel();
		}

		function pausePlayer() {
			var media = slot.firstElementChild;
			if (media) {
				if (media.tagName === 'VIDEO') {
					media.pause();
				} else if (media.tagName === 'IFRAME') {
					media.removeAttribute('src');
				}
			}
			clearPlayer();
		}

		function showPlayer() {
			if (dismissed) return;
			if (hideOnMobile && mql.matches) {
				hidePlayer();
				return;
			}
			buildPlayer();
			container.classList.remove('d-none');
			
			// For MP4s, only show when playback actually starts to avoid black screen 
			if (currentVideo && currentVideo.tagName === 'VIDEO') {
				currentVideo.addEventListener('playing', function() {
					container.classList.add('product-floating-video--visible');
				}, { once: true });
			} else {
				requestAnimationFrame(function() {
					container.classList.add('product-floating-video--visible');
				});
			}
		}

		function hidePlayer(permanent) {
			container.classList.remove('product-floating-video--visible');
			if (permanent) {
				dismissed = true;
			}
			pausePlayer();
			if (permanent) {
				container.classList.add('d-none');
			}
		}

		observer = new IntersectionObserver(function(entries) {
			entries.forEach(function(entry) {
				if (entry.isIntersecting) {
					if (!userScrolled) {
						hidePlayer();
					}
				} else {
					showPlayer();
				}
			});
		}, { threshold: 0.35 });

		observer.observe(gallery);

		function handleFirstScroll() {
			userScrolled = true;
			showPlayer();
			window.removeEventListener('scroll', handleFirstScroll);
		}

		window.addEventListener('scroll', handleFirstScroll, { passive: true });

		if (closeBtn) {
			closeBtn.addEventListener('click', function() {
				hidePlayer(true);
				if (observer) {
					observer.disconnect();
				}
			});
		}

		if (muteBtn) {
            debugLog("Attaching click listener to muteBtn");
			muteBtn.addEventListener('click', function() {
                debugLog("Mute button clicked");
				setMuteState(!isMuted);
			});
		}

		if (hideOnMobile) {
			mql.addEventListener('change', function() {
				if (mql.matches) {
					hidePlayer();
				}
			});
		}
	})();
	</script>
{%- endif -%}

