{%- if name != blank -%}
    {% capture icon_html %}
        {% render 'theme-icon', name: name %}
    {% endcapture %}
    {%- unless icon_html contains "Liquid error" -%}
        {%- if attr != blank -%}
            {%- assign tag_attr = '<svg ' | append: attr -%}
            {%- assign icon_html = icon_html | replace: '<svg', tag_attr -%}
        {%- endif -%}
        {{ icon_html }}
    {%- endunless -%}
{%- endif -%}
{%- assign attr = null -%}
