{%- comment -%}
================================================================================
Product Schema - JSON-LD Structured Data
================================================================================
Outputs Product structured data for Google Rich Results and Merchant Listings.
This is the theme's default Product schema markup.
================================================================================
{%- endcomment -%}
{%- assign offer_currency = localization.country.currency.iso_code | default: shop.currency -%}
{%- assign rating_value = product.metafields.reviews.rating.value | default: product.metafields.reviews.rating -%}
{%- assign rating_count = product.metafields.reviews.rating_count.value | default: product.metafields.reviews.rating_count -%}
{%- if rating_value == blank or rating_count == blank -%}
  {%- assign rating_value = product.metafields.judgeme.rating -%}
  {%- assign rating_count = product.metafields.judgeme.review_count -%}
{%- endif -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Product",
  "name": {{ product.title | strip | json }},
  "url": {{ shop.url | append: product.url | json }},
  {% if product.media.size > 0 %}
  "image": [
    {%- assign image_output = false -%}
    {%- for media in product.media -%}
      {%- if media.preview_image -%}
        {%- if image_output -%},{%- endif -%}
        {{ media.preview_image | img_url: 'master' | prepend: 'https:' | json }}
        {%- assign image_output = true -%}
      {%- endif -%}
    {%- endfor -%}
  ],
  {% endif %}
  "description": {{ product.description | strip_html | strip | json }},
  "brand": {
    "@type": "Brand",
    "name": {{ product.vendor | default: shop.name | json }}
  },
  "offers": [
    {%- for variant in product.variants -%}
    {
      "@type": "Offer",
      "url": {{ shop.url | append: variant.url | json }},
      {% if variant.barcode != blank %}
        "gtin": {{ variant.barcode | json }},
      {% elsif variant.sku != blank %}
        "mpn": {{ variant.sku | json }},
      {% endif %}
      {% if variant.sku != blank %}
      "sku": {{ variant.sku | json }},
      {% endif %}
      "price": {{ variant.price | divided_by: 100.0 | json }},
      "priceCurrency": {{ offer_currency | json }},
      "priceValidUntil": "{{ 'now' | date: '%s' | plus: 2592000 | date: '%Y-%m-%d' }}",
      "availability": "https://schema.org/{% if variant.available %}InStock{% else %}OutOfStock{% endif %}",
      "itemCondition": "https://schema.org/NewCondition",
      "shippingDetails": {
        "@type": "OfferShippingDetails",
        "shippingRate": {
          "@type": "MonetaryAmount",
          "value": {% assign threshold = settings.cart_free_shipping_value | plus: 0 %}{% if settings.cart_show_free_shipping and variant.price >= threshold %}0{% else %}7.95{% endif %},
          "currency": {{ offer_currency | json }}
        },
        "shippingDestination": {
          "@type": "DefinedRegion",
          "addressCountry": "US"
        },
        "deliveryTime": {
          "@type": "ShippingDeliveryTime",
          "handlingTime": {
            "@type": "QuantitativeValue",
            "minValue": 1,
            "maxValue": 2,
            "unitCode": "DAY"
          },
          "transitTime": {
            "@type": "QuantitativeValue",
            "minValue": 3,
            "maxValue": 7,
            "unitCode": "DAY"
          }
        }
      },
      "hasMerchantReturnPolicy": {
        "@type": "MerchantReturnPolicy",
        "applicableCountry": "US",
        "returnPolicyCategory": "https://schema.org/MerchantReturnFiniteReturnWindow",
        "merchantReturnDays": 45,
        "returnMethod": "https://schema.org/ReturnByMail",
        "returnFees": "https://schema.org/FreeReturn"
      }
    }{% unless forloop.last %},{% endunless %}
    {%- endfor -%}
  ]{%- if rating_value != blank and rating_count != blank and rating_count != 0 -%},
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": {{ rating_value | json }},
    "reviewCount": {{ rating_count | json }}
  }
  {%- endif -%}
}
</script>
