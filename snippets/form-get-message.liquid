{%- assign default_message_text = 'general.form.default.success' | t -%}
{%- assign loc_message_text = message_text | default: default_message_text -%}
{%- if form.errors -%}
    {%- assign res_error_fields = null -%}
    <div class="note note--error" role="alert" aria-live="assertive">
        <ul>
            {%- for field in form.errors -%}
                {%- if forloop.first != true -%}
                    {%- assign res_error_fields = res_error_fields | append: '|' -%}
                {%- endif -%}
                {%- assign res_error_fields = res_error_fields | append: field -%}
                <li>
                    {%- if field == 'form' -%}
                        {{ form.errors.messages[field] }}
                    {%- else -%}
                        {{ form.errors.translated_fields[field] }} - {{ form.errors.messages[field] }}
                    {%- endif -%}
                </li>
            {%- endfor -%}
        </ul>
    </div>
{%- endif -%}
{%- assign res_error_fields = res_error_fields | default: '' | split: '|' -%}
{%- if form.posted_successfully? -%}
    <div class="note note--success mt-20" id="ResetSuccess" role="status" aria-live="polite">{{ loc_message_text }}</div>
{%- endif -%}
