<div class="popup-size-guide position-relative py-30 px-15" data-popup-content>
    <i class="popup-size-guide__close position-absolute cursor-pointer" data-js-popup-close>{% render 'icon-theme-164' %}</i>
    <div class="popup-size-guide__content mx-auto" data-popup-size-guide-content>
        <div class="rte">
            {%- comment -%}
                Size Chart Priority:
                1. Product metafield (manual override)
                2. Auto-detect by product type → {product-type}-size-chart page
                3. Global fallback from theme settings
            {%- endcomment -%}

            {%- if product.metafields.sizeguide.html and product.metafields.sizeguide.html != 'hide' -%}
                {%- comment -%} Priority 1: Manual metafield override {%- endcomment -%}
                {{ product.metafields.sizeguide.html }}

            {%- elsif product.type != blank -%}
                {%- comment -%} Priority 2: Auto-detect by product type {%- endcomment -%}
                {%- assign product_type_handle = product.type | handleize -%}
                {%- assign size_chart_page_handle = product_type_handle | append: '-size-chart' -%}

                {%- if pages[size_chart_page_handle] != blank and pages[size_chart_page_handle].content != blank -%}
                    {{ pages[size_chart_page_handle].content }}
                {%- else -%}
                    {% render 'parse-page-html-content', default_page: 'include-popup-size-guide', page_content: settings.product_info_size_guide_page_content %}
                {%- endif -%}

            {%- else -%}
                {%- comment -%} Priority 3: No product type, use global fallback {%- endcomment -%}
                {% render 'parse-page-html-content', default_page: 'include-popup-size-guide', page_content: settings.product_info_size_guide_page_content %}
            {%- endif -%}
        </div>
    </div>
</div>