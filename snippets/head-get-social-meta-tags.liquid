{%- comment -%}
================================================================================
Social Meta Tags - Open Graph and Twitter Card
================================================================================
Outputs Open Graph and Twitter Card meta tags for proper social media sharing.
This snippet handles meta tags for products, articles, collections, and default pages.
================================================================================
{%- endcomment -%}
{%- assign og_title = page_title -%}
{%- assign og_url = canonical_url -%}
{%- assign og_type = 'website' -%}
{%- assign og_description = page_description | default: shop.description | default: shop.name | replace: 'Free shipping on orders over $100', 'Free shipping on orders over $80' | replace: 'free shipping on orders over $100', 'free shipping on orders over $80' -%}
{%- assign twitter_image = blank -%}
{%- if settings.social_share_image or page_image -%}
  {% capture og_image_tags %}
<meta property="og:image" content="https:{{ settings.social_share_image | default: page_image | image_url: width: 1200, height: 1200 }}">
{% endcapture %}
  {% capture og_image_secure_url_tags %}
<meta property="og:image:secure_url" content="https:{{ settings.social_share_image | default: page_image | image_url: width: 1200, height: 1200 }}">
{% endcapture %}
  {%- assign twitter_image = settings.social_share_image | default: page_image | image_url: width: 1200, height: 1200 | prepend: 'https:' -%}
{%- endif -%}
{% comment %} Template specific overides {% endcomment %}
{%- if template.name == 'product' -%}
  {%- assign og_title = product.title | strip_html -%}
  {%- assign og_type = 'product' -%}
  {%- if product.media.size > 0 -%}
    {% capture og_image_tags %}{% for media in product.media limit:3 -%}
<meta property="og:image" content="https:{{ media | image_url: width: 1200, height: 1200 }}">
{% endfor -%}{% endcapture -%}
    {% capture og_image_secure_url_tags %}{% for media in product.media limit:3 -%}
<meta property="og:image:secure_url" content="https:{{ media | image_url: width: 1200, height: 1200 }}">
{% endfor -%}{% endcapture -%}
    {%- assign twitter_image = product.featured_media | image_url: width: 1200, height: 1200 | prepend: 'https:' -%}
  {%- endif -%}
{%- elsif template.name == 'article' -%}
  {%- assign og_title = article.title | strip_html -%}
  {%- assign og_type = 'article' -%}
  {%- assign og_description = article.excerpt_or_content | strip_html -%}
  {%- if article.image -%}
    {% capture og_image_tags %}
<meta property="og:image" content="https:{{ article.image | image_url: width: 1200, height: 1200 }}">
{% endcapture %}
    {% capture og_image_secure_url_tags %}
<meta property="og:image:secure_url" content="https:{{ article.image | image_url: width: 1200, height: 1200 }}">
{% endcapture %}
    {%- assign twitter_image = article.image | image_url: width: 1200, height: 1200 | prepend: 'https:' -%}
  {%- endif -%}
{%- elsif template.name == 'collection' -%}
  {%- assign og_title = collection.title | strip_html -%}
  {%- assign og_type = 'product.group' -%}
  {%- if collection.image -%}
    {% capture og_image_tags %}
<meta property="og:image" content="https:{{ collection.image | image_url: width: 1200, height: 1200 }}">
{% endcapture %}
    {% capture og_image_secure_url_tags %}
<meta property="og:image:secure_url" content="https:{{ collection.image | image_url: width: 1200, height: 1200 }}">
{% endcapture %}
    {%- assign twitter_image = collection.image | image_url: width: 1200, height: 1200 | prepend: 'https:' -%}
  {%- endif -%}
{%- elsif template.name == 'password' -%}
  {%- assign og_title = shop.name -%}
  {%- assign og_url = shop.url -%}
  {%- assign og_description = shop.description | default: shop.name | replace: 'Free shipping on orders over $100', 'Free shipping on orders over $80' | replace: 'free shipping on orders over $100', 'free shipping on orders over $80' -%}
{%- endif -%}
<meta property="og:site_name" content="{{ shop.name | escape }}">
<meta property="og:url" content="{{ og_url | escape }}">
<meta property="og:title" content="{{ og_title | strip_html | strip | escape }}">
<meta property="og:type" content="{{ og_type }}">
<meta property="og:description" content="{{ og_description | strip_html | strip | truncate: 320 | escape }}">
{%- if template.name == 'product' -%}
<meta property="og:price:amount" content="{{ product.price | money_without_currency | strip_html }}">
<meta property="og:price:currency" content="{{ cart.currency.iso_code }}">
{%- endif -%}
{{ og_image_tags }}
{{ og_image_secure_url_tags }}
{%- unless settings.social_twitter == blank -%}
<meta name="twitter:site" content="{{ settings.social_twitter | split: 'twitter.com/' | last | prepend: '@' }}">
{%- endunless -%}
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ og_title | strip_html | strip | escape }}">
<meta name="twitter:description" content="{{ og_description | strip_html | strip | truncate: 320 | escape }}">
{%- if twitter_image != blank %}
<meta name="twitter:image" content="{{ twitter_image | escape }}">
{%- endif -%}
{%- comment -%}
Organization Schema - JSON-LD Structured Data
{%- endcomment -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": {{ shop.name | json }},
  "url": {{ shop.url | json }},
  {% if settings.logo %}
  "logo": {{ settings.logo | image_url: width: 512, height: 512 | prepend: 'https:' | json }},
  {% endif %}
  {% if shop.email %}
  "email": {{ shop.email | json }},
  {% endif %}
  "sameAs": [
    {%- assign social_links_raw = '' -%}
    {%- if settings.social_facebook_link != blank -%}
      {%- assign social_links_raw = social_links_raw | append: settings.social_facebook_link | append: '||' -%}
    {%- endif -%}
    {%- if settings.social_instagram_link != blank -%}
      {%- assign social_links_raw = social_links_raw | append: settings.social_instagram_link | append: '||' -%}
    {%- endif -%}
    {%- if settings.social_twitter_link != blank -%}
      {%- assign social_links_raw = social_links_raw | append: settings.social_twitter_link | append: '||' -%}
    {%- endif -%}
    {%- if settings.social_pinterest_link != blank -%}
      {%- assign social_links_raw = social_links_raw | append: settings.social_pinterest_link | append: '||' -%}
    {%- endif -%}
    {%- if settings.social_youtube_link != blank -%}
      {%- assign social_links_raw = social_links_raw | append: settings.social_youtube_link | append: '||' -%}
    {%- endif -%}
    {%- assign social_links = social_links_raw | split: '||' -%}
    {%- assign last_index = social_links.size | minus: 1 -%}
    {%- for link in social_links -%}
      {%- unless link == '' -%}
        {{ link | json }}{% if forloop.index0 < last_index %},{% endif %}
      {%- endunless -%}
    {%- endfor -%}
  ]
}
</script>
