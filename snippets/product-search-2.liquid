{%- assign forloop_index0 = forloop_index0 | default: 0 -%}
{% include 'global-variables' %}
{% include 'product-res-variables' %}
{%- if image == blank and product.featured_image -%}
  {%- assign image = product.featured_image -%}
{%- endif -%}
{%- assign image_size = '200x' -%}
{%- assign show_title = show_title | default: settings.product_collection_show_title -%}
{%- assign show_price = show_price | default: settings.product_collection_show_price -%}
<div class="product-search-2 d-flex{% if forloop_index0 > 0 %} mt-15{% endif %}">
    <div class="product-search-2__image mr-10">
        <a href="{{ url }}" class="d-block">
            {%- if image -%}
                {% render 'rimage' image: image size: image_size stretch_size: settings.product_collection_image_size disable_lazyload: disable_lazyload %}
            {%- else -%}
                {%- # theme-check-disable-next-line RemoteAsset -%}
                <img src="data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///yH5BAEAAAAALAAAAAABAAEAAAIBRAA7" alt="{{ title | escape }}" width="200" height="200" loading="lazy" decoding="async">
            {%- endif -%}
        </a>
    </div>
    <div class="product-search-2__content d-flex flex-column justify-content-center ml-3">
        {%- if show_title -%}
            <div class="product-search-2__title mb-5">
                <h3 class="h6 m-0">
                    <a href="{{ url }}">{{ title }}</a>
                </h3>
            </div>
        {%- endif -%}
        {%- if show_price -%}
            <div class="product-search-2__price">
                {% render 'product-get-price', price: price, compare_at_price: compare_at_price, current_variant: current_variant %}
            </div>
        {%- endif -%}
    </div>
</div>
