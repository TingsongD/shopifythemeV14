<div class="popup-quick-view position-relative px-15 pt-50 pb-25 pt-lg-30 overflow-hidden" data-popup-content>
    <style>
        .popup-quick-view__close .icon-theme-164 {
            fill: black !important;
            stroke: black !important;
            stroke-width: 1.5px;
        }
    </style>
    <i class="popup-quick-view__close position-absolute cursor-pointer" data-js-popup-close>{% render 'icon-theme-164' %}</i>
    <div class="popup-quick-view__content mx-auto" data-js-quick-view>{{ content }}</div>
</div>