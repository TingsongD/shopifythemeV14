{%- # theme-check-disable UnusedAssign -%}
{%- # theme-check-disable-next-line DeprecatedTag -%}
{% include 'global-variables' %}
{%- assign slick_parent_block = block -%}
{%- assign slider_index = 0 -%}
<div class="slider position-relative">
    {%- if slick_parent_block.settings.arrows -%}
        <div class="slider__prev d-none d-lg-block position-absolute cursor-pointer" data-js-slider-prev><i>{% render 'icon-theme-006' %}</i></div>
    {%- endif -%}
    <div class="slider__slick js-slider-tracking"
         data-js-slider-slick
         data-arrows="{{ slick_parent_block.settings.arrows }}"
         data-bullets="{{ slick_parent_block.settings.bullets }}"
         data-speed="{{ slick_parent_block.settings.speed }}">
        {%- for block in section.blocks offset: parent_block_offset -%}
            {%- if block.type != 'slick_slide' -%}
                {%- break -%}
            {%- endif -%}
        {%- liquid
            if slider_index > 0
                assign slide_video_lazy = true
            else
                assign slide_video_lazy = false
            endif
        -%}
        {% capture inner_block_id %}{{ block_id }}-{{ forloop.index }}{% endcapture %}
            {% if block.settings.link != blank %}
                <a href="{{ block.settings.link }}" data-target="_blank" class="slider__slide {{ inner_block_id }}"
                    {% if block.settings.delay > 0 %}data-delay="{{ block.settings.delay | times: 1000 }}"{% endif %}>
            {% else %}
                <div class="slider__slide {{ inner_block_id }}"
                    {% if block.settings.delay > 0 %}data-delay="{{ block.settings.delay | times: 1000 }}"{% endif %}>
            {% endif %}
                {% render 'promobox' with block: block block_id: inner_block_id video_lazyload: slide_video_lazy promobox_curtain_opacity: promobox_curtain_opacity promobox_height_preset_1: promobox_height_preset_1 promobox_height_preset_2: promobox_height_preset_2 promobox_height_preset_3: promobox_height_preset_3 promobox_ultra_height_preset_1: promobox_ultra_height_preset_1 promobox_ultra_height_preset_3: promobox_ultra_height_preset_3 height: slick_parent_block.settings.height min_height: slick_parent_block.settings.min_height is_slider: true %}
            {% if block.settings.link != blank %}
                </a>
            {% else %}
                </div>
            {% endif %}
            {%- assign slider_index = slider_index | plus: 1 -%}
        {%- endfor -%}
    </div>
    {%- if slick_parent_block.settings.arrows -%}
        <div class="slider__next d-none d-lg-block position-absolute cursor-pointer" data-js-slider-next><i>{% render 'icon-theme-007' %}</i></div>
    {%- endif -%}
</div>
{%- # theme-check-enable UnusedAssign -%}
